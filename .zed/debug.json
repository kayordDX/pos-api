[
  {
    "label": "Debug .NET Core App",
    "adapter": "netcoredbg",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/src/Kayord.Pos/bin/Debug/net10.0/Kayord.Pos.dll",
    "cwd": "${ZED_WORKTREE_ROOT}/src/Kayord.Pos",
    "env": {
      "ASPNETCORE_ENVIRONMENT": "Development",
      "ASPNETCORE_URLS": "http://localhost:5117",
    },
    "build": {
      "command": "dotnet",
      "args": [
        "build",
        "${ZED_WORKTREE_ROOT}/src/Kayord.Pos/Kayord.Pos.csproj",
        "-p:Configuration=Debug",
      ],
    },
  },
]
